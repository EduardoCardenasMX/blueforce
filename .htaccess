DirectoryIndex index.html

RewriteEngine On

# Canonical host, HTTPS, and clean URLs in one hop for common entry points.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^blueforce\.cloud$ [NC]
RewriteRule ^index(?:\.html)?/?$ https://blueforce.cloud/ [R=301,L]

RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^blueforce\.cloud$ [NC]
RewriteRule ^(.+?)\.html$ https://blueforce.cloud/$1 [R=301,L]

RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^blueforce\.cloud$ [NC]
RewriteRule ^(.+)$ https://blueforce.cloud/$1 [R=301,L]

RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^blueforce\.cloud$ [NC]
RewriteRule ^$ https://blueforce.cloud/ [R=301,L]

# Clean URLs for already-canonical requests.
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteRule ^index/?$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# Serve extensionless URLs from their matching .html files.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Compress text-based assets when Apache modules are available.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Cache static assets aggressively; query-string versions bust stale files.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/html "access plus 5 minutes"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|jpg|jpeg|png|webp|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
